QDRANT_ENDPOINT=
QDRANT_API_KEY=
GEMINI_API_KEY=

LLM_API_KEY=
# Endpoint for any OpenAI-compatible provider. When set, requests route to
# this URL; when unset, the provider's official endpoint is used.
# Examples: https://api.deepseek.com (DeepSeek), http://localhost:11434/v1 (ollama)
LLM_BASE_URL=
# Model name to use (defaults to gpt-4o when unset).
# Examples: deepseek-chat, qwen-plus, glm-4-plus, gpt-4o
LLM_MODEL_NAME=

# Optional LangSmith tracing and logging
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=